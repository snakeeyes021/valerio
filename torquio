    echo -e "${gray}================================================================${reset}"
    echo -e "${wine} ████████╗  ██████╗  ██████╗   ██████╗  ██╗   ██╗ ██╗  ██████╗ ${reset}"
    echo -e "${wine} ╚══██╔══╝ ██╔═══██╗ ██╔══██╗ ██╔═══██╗ ██║   ██║ ██║ ██╔═══██╗${reset}"
    echo -e "${wine}    ██║    ██║   ██║ ██████╔╝ ██║   ██║ ██║   ██║ ██║ ██║   ██║${reset}"
    echo -e "${wine}    ██║    ██║   ██║ ██╔══██╗ ██║▄▄ ██║ ██║   ██║ ██║ ██║   ██║${reset}"
    echo -e "${wine}    ██║    ╚██████╔╝ ██║  ██║ ╚██████╔╝ ╚██████╔╝ ██║ ╚██████╔╝${reset}"
    echo -e "${wine}    ╚═╝     ╚═════╝  ╚═╝  ╚═╝  ╚══▀▀═╝   ╚═════╝  ╚═╝  ╚═════╝ ${reset}"
    echo -e "${wine}                              —— B Y  R E D  F O X  L A B S ——${reset}"
    echo -e "${gray}================================================================${reset}"
    
    # System Clock Status Check (SAM/SDA licensing safeguard)
    python3 -c "
import urllib.request, time, datetime
try:
    req = urllib.request.Request('https://www.google.com', method='HEAD')
    with urllib.request.urlopen(req, timeout=3) as response:
        srv_date_str = response.headers.get('Date')
    if srv_date_str:
        srv_time = time.strptime(srv_date_str, '%a, %d %b %Y %H:%M:%S GMT')
        srv_dt = datetime.datetime(*srv_time[:6], tzinfo=datetime.timezone.utc)
        local_dt = datetime.datetime.now(datetime.timezone.utc)
        diff = abs((srv_dt - local_dt).total_seconds())
        if diff > 180:
            print('')
            print('\033[38;5;179mSystem Clock Status:\033[0m')
            print(f'  \033[38;5;167mWARNING: System clock is out of sync by {int(diff)} seconds!\033[0m')
            print(f'  Server Time (UTC): {srv_dt.strftime(\"%Y-%m-%d %H:%M:%S\")}')
            print(f'  System Time (UTC): {local_dt.strftime(\"%Y-%m-%d %H:%M:%S\")}')
            print('  This is \033[38;5;167mHIGHLY LIKELY\033[0m to cause errors in the Steinberg Activation Manager.')
except Exception:
    print('')
    print('\033[38;5;244mSystem Clock Status:\033[0m')
    print('  \033[38;5;179mWARNING: Torquio attempts to verify that your system clock is\033[0m')
    print('  \033[38;5;179maccurate in order to prevent SAM licensing issues. Offline or\033[0m')
    print('  \033[38;5;179munable to contact time server. System clock could not be verified.\033[0m')
"
    
}

get_config_val() {
    local key="$1"
    local default="$2"
    local config_file="$HOME/.config/torquio/config.json"
    if [ ! -f "$config_file" ]; then
        echo "$default"
        return
    fi
    python3 -c "import json; d=json.load(open('$config_file')); print(d.get('$key', '$default'))" 2>/dev/null || echo "$default"
}

set_config_val() {
    local key="$1"
    local val="$2"
    local config_file="$HOME/.config/torquio/config.json"
    mkdir -p "$(dirname "$config_file")"
    if [ ! -f "$config_file" ]; then
        echo "{}" > "$config_file"
    fi
    python3 -c "
import json
f = '$config_file'
try: d = json.load(open(f))
except Exception: d = {}
val = '$val'
if val.lower() == 'true': val = True
elif val.lower() == 'false': val = False
elif val.isdigit(): val = int(val)
d['$key'] = val
json.dump(d, open(f, 'w'), indent=4)
" 2>/dev/null || true
}

apply_graphics_settings() {
    # Check if container is created and prefix is initialized first
    if ! distrobox list 2>/dev/null | grep -q "$TORQUIO_CONTAINER_NAME" || [ ! -d "$TORQUIO_PREFIX_DIR" ]; then
        return
    fi

    echo "Applying graphics settings to Wine prefix..."
    
    local auto_dpi=$(get_config_val "auto_dpi_detect" "true")
    local manual_dpi=$(get_config_val "manual_dpi" "96")
    local ft_int=$(get_config_val "freetype_interpreter" "40")
    local dpi_to_set="$manual_dpi"

    if [ "$auto_dpi" = "true" ]; then
        local host_scale=1
        if command -v gsettings >/dev/null 2>&1; then
            local g_scale=$(gsettings get org.gnome.desktop.interface scaling-factor 2>/dev/null | awk '{print $2}')
            if [ -n "$g_scale" ] && [ "$g_scale" -gt 0 ]; then
                host_scale="$g_scale"
            fi
        fi
        if [ "$host_scale" = "1" ] && command -v gsettings >/dev/null 2>&1; then
            local text_scale=$(gsettings get org.gnome.desktop.interface text-scaling-factor 2>/dev/null | awk '{print $2}')
            if [ -n "$text_scale" ] && (( $(echo "$text_scale > 1.0" | bc -l 2>/dev/null || echo "0") )); then
                host_scale=$(echo "$host_scale * $text_scale" | bc -l 2>/dev/null)
            fi
        fi
        if [ "$host_scale" = "1" ] && command -v xrdb >/dev/null 2>&1; then
            local xrdb_dpi=$(xrdb -query 2>/dev/null | grep -i Xft.dpi | awk '{print $2}')
            if [ -n "$xrdb_dpi" ]; then
                host_scale=$(echo "scale=2; $xrdb_dpi / 96" | bc -l 2>/dev/null)
            fi
        fi
        
        dpi_to_set=$(echo "$host_scale * 96" | bc -l 2>/dev/null | awk '{print int($1 + 0.5)}')
        if [ -z "$dpi_to_set" ] || [ "$dpi_to_set" -lt 96 ]; then
            dpi_to_set=96
        fi
    fi

    # Write registry value inside container
    distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wine reg add \"HKCU\\Control Panel\\Desktop\" /v LogPixels /t REG_DWORD /d $dpi_to_set /f" >/dev/null 2>&1 || true

    # Kill wine server to apply changes immediately
    echo "Restarting Wine server to load changes..."
    distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; wineserver -k" >/dev/null 2>&1 || true
    echo "Graphics settings successfully applied."
}

configure_graphics() {
    local wine="\033[38;5;125m"
    local reset="\033[0m"
    local blue="\033[38;5;110m"

    echo -e "${blue}=== Torquio Graphics & Scaling Configuration ===${reset}"
    echo ""
    local cur_auto_scale=$(get_config_val "auto_scale_mutter" "false")
    local cur_auto_dpi=$(get_config_val "auto_dpi_detect" "true")
    local cur_manual_dpi=$(get_config_val "manual_dpi" "96")
    local cur_interpreter=$(get_config_val "freetype_interpreter" "40")
    
    echo "Current settings:"
    echo -e "  ${wine}1)${reset} Auto-Scale XWayland (auto_scale_mutter): $cur_auto_scale"
    echo -e "  ${wine}2)${reset} Auto-DPI Detection (auto_dpi_detect):    $cur_auto_dpi"
    echo -e "  ${wine}3)${reset} Manual DPI Fallback (manual_dpi):        $cur_manual_dpi"
    echo -e "  ${wine}4)${reset} FreeType Hinting Interpreter (v35/v40):  v$cur_interpreter"
    echo -e "  ${wine}5)${reset} [Back to main menu]"
    echo ""
    read -p "Select an option to toggle/change (1-5): " opt
    case "$opt" in
        1)
            if [ "$cur_auto_scale" = "true" ]; then
                set_config_val "auto_scale_mutter" "false"
            else
                set_config_val "auto_scale_mutter" "true"
            fi
            echo "Toggle applied!"
            apply_graphics_settings
            configure_graphics
            ;;
        2)
            if [ "$cur_auto_dpi" = "true" ]; then
                set_config_val "auto_dpi_detect" "false"
            else
                set_config_val "auto_dpi_detect" "true"
            fi
            echo "Toggle applied!"
            apply_graphics_settings
            configure_graphics
            ;;
        3)
            echo "Standard default DPI is 96."
            read -p "Enter manual DPI value (e.g. 96, 120, 144, 192): " new_dpi
            if [[ "$new_dpi" =~ ^[0-9]+$ ]]; then
                set_config_val "manual_dpi" "$new_dpi"
                echo "Manual DPI updated to $new_dpi!"
                apply_graphics_settings
            else
                echo "Invalid input. DPI must be an integer."
            fi
            configure_graphics
            ;;
        4)
            echo ""
            echo -e "${blue}=== FreeType Hinting Interpreter Selection ===${reset}"
            echo -e "  ${wine}1)${reset} v40 (Thicker/bolder, but some fonts can look smudgey) [Default]"
            echo -e "  ${wine}2)${reset} v35 (Thinner/crisper, but some fonts can look anemic)"
            echo -e "  ${wine}3)${reset} [Back to graphics menu]"
            echo ""
            read -p "Select interpreter style (1-3): " choice_int
            case "$choice_int" in
                1)
                    set_config_val "freetype_interpreter" "40"
                    echo "FreeType Hinting Interpreter set to v40!"
                    apply_graphics_settings
                    echo ""
                    read -p "Press [Enter] to continue..." temp_int
                    ;;
                2)
                    set_config_val "freetype_interpreter" "35"
                    echo "FreeType Hinting Interpreter set to v35!"
                    apply_graphics_settings
                    echo ""
                    read -p "Press [Enter] to continue..." temp_int
                    ;;
                *)
                    # Return immediately when choosing back or invalid entry
                    ;;
            esac
            configure_graphics
            ;;
        *)
            return
            ;;
    esac
}

show_status() {
    local wine="\033[38;5;125m"
    local gray="\033[38;5;244m"
    local dark_gray="\033[38;5;240m"
    local green="\033[38;5;108m"
    local red="\033[38;5;167m"
    local blue="\033[38;5;110m"
    local reset="\033[0m"

    echo -e "${gray}================================================================${reset}"
    echo -e "             ${wine}Torquio Environment Dashboard${reset}                "
    echo -e "${gray}================================================================${reset}"
    echo ""
    
    # 1. Distrobox Container Status
    echo -e "${blue}Distrobox Container Status:${reset}"
    if distrobox list 2>/dev/null | grep -q "$TORQUIO_CONTAINER_NAME"; then
        local cont_status=$(distrobox list 2>/dev/null | grep "$TORQUIO_CONTAINER_NAME" | awk -F'|' '{print $4}' | tr -d '[:space:]')
        echo -e "  - Container: ${dark_gray}$TORQUIO_CONTAINER_NAME${reset} (Active: ${green}${cont_status:-running}${reset})"
    else
        echo -e "  - Container: ${dark_gray}$TORQUIO_CONTAINER_NAME${reset} (${red}Not Created${reset})"
    fi
    echo ""
    
    # 2. Wine Prefix Status
    echo -e "${blue}Wine Prefix Status:${reset}"
    if [ -d "$TORQUIO_PREFIX_DIR" ]; then
        local pref_size=$(du -sh "$TORQUIO_PREFIX_DIR" 2>/dev/null | awk '{print $1}')
        echo -e "  - Wine Prefix: ${dark_gray}$TORQUIO_PREFIX_DIR${reset} (Size: ${wine}$pref_size${reset})"
        if [ -f "$TORQUIO_PREFIX_DIR/.torquio_core_installed" ]; then
            echo -e "  - Core Wine Dependencies:   ${green}Installed${reset} (dotnet48, vcrun2019, wine-icu)"
        else
            echo -e "  - Core Wine Dependencies:   ${red}Incomplete${reset} (Run installation to fix)"
        fi
    else
        echo -e "  - Wine Prefix: ${red}Not Initialized${reset} (Run installation to create)"
    fi
    echo ""
    
    # 3. Active Preferences Profile
    echo -e "${blue}Configuration Preferences:${reset}"
    local auto_scale=$(get_config_val "auto_scale_mutter" "false")
    local auto_dpi=$(get_config_val "auto_dpi_detect" "true")
    local manual_dpi=$(get_config_val "manual_dpi" "96")
    local freetype_interp=$(get_config_val "freetype_interpreter" "40")
    local orig_scale=$(get_config_val "original_scale_factor" "Not saved")
    echo -e "  - auto_scale_mutter:     ${wine}$auto_scale${reset}"
    echo -e "  - auto_dpi_detect:       ${wine}$auto_dpi${reset}"
    echo -e "  - manual_dpi:            ${wine}$manual_dpi${reset}"
    echo -e "  - freetype_interpreter:  ${wine}v$freetype_interp${reset}"
    if [ "$auto_scale" = "true" ]; then
        echo -e "  - original_scale_factor: ${wine}$orig_scale${reset}"
    fi
    echo ""
    
    # 4. Host Info
    echo -e "${blue}Host System Details:${reset}"
    echo -e "  - Desktop Environment:   ${wine}$XDG_CURRENT_DESKTOP${reset}"
    if command -v gsettings >/dev/null 2>&1; then
        local g_scale=$(gsettings get org.gnome.desktop.interface scaling-factor 2>/dev/null | awk '{print $2}')
        local g_mutter=$(gsettings get org.gnome.mutter xwayland-scaling-factor 2>/dev/null | awk '{print $2}')
        echo -e "  - GNOME Scale Factor:    ${wine}${g_scale:-Unknown}${reset}"
        echo -e "  - Mutter XWayland Scale: ${wine}${g_mutter:-Unknown}${reset}"
    fi
    echo -e "${gray}================================================================${reset}"
    echo ""
}

map_folder() {
    local host_folder="$1"
    local drive_letter="$2"
    
    if [ -z "$host_folder" ] || [ -z "$drive_letter" ]; then
        echo "=== Map Local Folder as Wine Drive ==="
        if command -v zenity >/dev/null 2>&1; then
            host_folder=$(zenity --file-selection --directory --title="Select Folder to Map" 2>/dev/null) || true
        elif command -v kdialog >/dev/null 2>&1; then
            host_folder=$(kdialog --getexistingdirectory --title="Select Folder to Map" 2>/dev/null) || true
        else
            read -p "Enter the absolute path of the local folder: " host_folder
        fi
        
        if [ -z "$host_folder" ] || [ ! -d "$host_folder" ]; then
            echo "Error: Invalid folder path. Mapping cancelled."
            return 1
        fi
        
        for letter in d e f g h i j k l m n o p q r s t u v w x y z; do
            if [ ! -e "$TORQUIO_PREFIX_DIR/dosdevices/${letter}:" ]; then
                drive_letter="${letter}:"
                break
            fi
        done
        
        if [ -z "$drive_letter" ]; then
            echo "Error: No available drive letters left!"
            return 1
        fi
    fi
    
    local real_host_folder=$(realpath "$host_folder")
    drive_letter=$(echo "$drive_letter" | tr '[:upper:]' '[:lower:]')
    if [[ ! "$drive_letter" =~ :$ ]]; then
        drive_letter="${drive_letter}:"
    fi
    
    if [ ! -d "$real_host_folder" ]; then
        echo "Error: Local folder '$real_host_folder' does not exist."
        return 1
    fi
    
    if [ ! -d "$TORQUIO_PREFIX_DIR/dosdevices" ]; then
        echo "Error: Wine prefix has not been initialized. Please run setup first."
        return 1
    fi
    
    local link_path="$TORQUIO_PREFIX_DIR/dosdevices/$drive_letter"
    if [ -L "$link_path" ]; then
        local current_target=$(readlink -f "$link_path")
        if [ "$current_target" = "$real_host_folder" ]; then
            echo "Folder '$real_host_folder' is already mapped to Wine drive ${drive_letter^^}\\"
            return 1
        fi
    fi
    
    rm -f "$link_path"
    ln -s "$real_host_folder" "$link_path"
    echo "Successfully mapped '$real_host_folder' to Wine drive ${drive_letter^^}\\"
    return 0
}

unmap_folder() {
    echo "=== Unmap Local Folder ==="
    if [ ! -d "$TORQUIO_PREFIX_DIR/dosdevices" ]; then
        echo "Error: Wine prefix has not been initialized. Please run setup first."
        return 1
    fi

    local mapped_drives=()
    local drive_letters=()
    for letter in d e f g h i j k l m n o p q r s t u v w x y; do
        local link_path="$TORQUIO_PREFIX_DIR/dosdevices/${letter}:"
        if [ -L "$link_path" ]; then
            local target=$(readlink -f "$link_path")
            mapped_drives+=("${letter^^}: -> $target")
            drive_letters+=("$letter")
        fi
    done

    if [ ${#mapped_drives[@]} -eq 0 ]; then
        echo "No mapped folders found."
        return 1
    fi

    echo "Currently mapped folders:"
    for i in "${!mapped_drives[@]}"; do
        echo "  $((i+1))) ${mapped_drives[$i]}"
    done
    echo "  $(( ${#mapped_drives[@]} + 1 ))) [Cancel]"
    echo ""
    read -p "Select a drive to unmap (1-$(( ${#mapped_drives[@]} + 1 ))): " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#mapped_drives[@]}" ]; then
        local idx=$((choice-1))
        local target_letter="${drive_letters[$idx]}"
        rm -f "$TORQUIO_PREFIX_DIR/dosdevices/${target_letter}:"
        echo "Successfully unmapped drive ${target_letter^^}:"
        return 0
    else
        echo "Operation cancelled."
        return 1
    fi
}

manage_folder_mappings() {
    local wine="\033[38;5;125m"
    local reset="\033[0m"
    local blue="\033[38;5;110m"

    while true; do
        echo -e "${blue}=== Manage Folder Mappings ===${reset}"
        echo ""
        echo -e "  ${wine}1)${reset} Map a Local Folder to Wine"
        echo -e "  ${wine}2)${reset} Unmap an Existing Wine Folder"
        echo -e "  ${wine}3)${reset} [Back to main menu]"
        echo ""
        read -p "Select an option (1-3): " opt_map
        case "$opt_map" in
            1)
                echo ""
                if map_folder; then
                    echo ""
                    read -p "Press [Enter] to continue..." temp_map
                fi
                ;;
            2)
                echo ""
                if unmap_folder; then
                    echo ""
                    read -p "Press [Enter] to continue..." temp_map
                fi
                ;;
            *)
                return
                ;;
        esac
        clear
    done
}

export_keycommands() {
    echo "=== Exporting Key Commands Backup ==="
    local keycommands_dir=$(find "$TORQUIO_PREFIX_DIR/drive_c/users" -type d -path "*/AppData/Roaming/Steinberg/Dorico*" 2>/dev/null | head -n 1)
    if [ -z "$keycommands_dir" ] || [ ! -d "$keycommands_dir" ]; then
        echo "Error: Dorico AppData directory not found. Please make sure Dorico has been installed and run."
        return
    fi
    
    mapfile -t files < <(find "$keycommands_dir" -type f -name "keycommands_*.json" 2>/dev/null)
    if [ ${#files[@]} -eq 0 ]; then
        echo "No keycommands_*.json files found to export."
        return
    fi
    
    echo "Found files to export:"
    for f in "${files[@]}"; do
        echo "  - $(basename "$f")"
    done
    
    local downloads_dir="${XDG_DOWNLOAD_DIR:-$HOME/Downloads}"
    mkdir -p "$downloads_dir"
    local zip_file="$downloads_dir/torquio_keycommands_backup.zip"
    
    (cd "$keycommands_dir" && zip -q "$zip_file" keycommands_*.json)
    echo "Successfully compressed and exported key commands to: $zip_file"
}

import_keycommands() {
    echo "=== Importing Key Commands Backup ==="
    local keycommands_dir=$(find "$TORQUIO_PREFIX_DIR/drive_c/users" -type d -path "*/AppData/Roaming/Steinberg/Dorico*" 2>/dev/null | head -n 1)
    if [ -z "$keycommands_dir" ] || [ ! -d "$keycommands_dir" ]; then
        echo "Error: Dorico AppData directory not found. Key commands import cancelled."
        return
    fi
    
    local downloads_dir="${XDG_DOWNLOAD_DIR:-$HOME/Downloads}"
    mapfile -t backups < <(find "$downloads_dir" -maxdepth 1 -type f \( -name "torquio_keycommands_backup.zip" -o -name "keycommands_*.json" \) 2>/dev/null)
    
    local selected_backup=""
    if [ ${#backups[@]} -eq 1 ]; then
        selected_backup="${backups[0]}"
        echo "Auto-detected backup file: $(basename "$selected_backup")"
    elif [ ${#backups[@]} -gt 1 ]; then
        echo "Multiple backup files found in $downloads_dir:"
        for i in "${!backups[@]}"; do
            echo "  $((i+1))) $(basename "${backups[$i]}")"
        done
        echo "  $(( ${#backups[@]} + 1 ))) [Browse...]"
        read -p "Select a file to import (1-$(( ${#backups[@]} + 1 ))): " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#backups[@]}" ]; then
            selected_backup="${backups[$((choice-1))]}"
        fi
    fi
    
    if [ -z "$selected_backup" ]; then
        if command -v zenity >/dev/null 2>&1; then
            selected_backup=$(zenity --file-selection --file-filter="Backup (*.zip *.json) | *.zip *.json" --title="Select Key Commands Backup File" 2>/dev/null) || true
        elif command -v kdialog >/dev/null 2>&1; then
            selected_backup=$(kdialog --getopenfilename "$downloads_dir" "*.zip *.json" --title="Select Key Commands Backup File" 2>/dev/null) || true
        else
            read -p "Enter path to key commands backup file (.zip or .json): " selected_backup
        fi
    fi
    
    if [ -z "$selected_backup" ] || [ ! -f "$selected_backup" ]; then
        echo "No backup file selected. Import cancelled."
        return
    fi
    
    echo "Importing: $selected_backup"
    if [[ "$selected_backup" =~ \.zip$ ]]; then
        unzip -o "$selected_backup" -d "$keycommands_dir"
    else
        cp "$selected_backup" "$keycommands_dir/"
    fi
    echo "Key commands successfully imported!"
}

manage_keycommands() {
    local wine="\033[38;5;125m"
    local reset="\033[0m"
    local blue="\033[38;5;110m"

    while true; do
        echo -e "${blue}=== Manage Dorico Key Commands ===${reset}"
        echo ""
        echo -e "  ${wine}1)${reset} Export Key Commands (Backup to Zip)"
        echo -e "  ${wine}2)${reset} Import Key Commands (Restore from Backup)"
        echo -e "  ${wine}3)${reset} [Back to main menu]"
        echo ""
        read -p "Select an option (1-3): " opt_kc
        case "$opt_kc" in
            1)
                export_keycommands
                ;;
            2)
                import_keycommands
                ;;
            *)
                return
                ;;
        esac
        echo ""
        read -p "Press [Enter] to continue..." temp_kc
    done
}

run_custom_exe() {
    echo "=== Run Custom Installer or Executable ==="
    echo ""
    local selected_exe="$1"
    
    if [ -z "$selected_exe" ]; then
        if command -v zenity >/dev/null 2>&1; then
            selected_exe=$(zenity --file-selection --file-filter="Executables (*.exe *.msi) | *.exe *.msi" --title="Select Executable to Run" 2>/dev/null) || true
        elif command -v kdialog >/dev/null 2>&1; then
            selected_exe=$(kdialog --getopenfilename "$HOME" "*.exe *.msi" --title="Select Executable to Run" 2>/dev/null) || true
        else
            read -p "Enter the absolute path to the .exe or .msi file: " selected_exe
        fi
    fi
    
    if [ -z "$selected_exe" ] || [ ! -f "$selected_exe" ]; then
        echo "No valid file selected. Operation cancelled."
        return
    fi
    
    echo "Running: $selected_exe"
    
    local translated_path=$(distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEDEBUG=-all; export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; winepath -w \"$selected_exe\"" | tr -d '\r')
    local ft_int=$(get_config_val "freetype_interpreter" "40")
    
    if [[ "$selected_exe" =~ \.msi$ ]]; then
        distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wine msiexec /i \"$translated_path\"" || true
    else
        distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wine \"$translated_path\"" || true
    fi
    
    echo "Execution completed."
}

manage_wine() {
    local wine="\033[38;5;125m"
    local reset="\033[0m"
    local blue="\033[38;5;110m"

    while true; do
        echo -e "${blue}=== Wine Tools & Maintenance ===${reset}"
        echo ""
        echo -e "  ${wine}1)${reset} Run Wine Configuration (winecfg)"
        echo -e "  ${wine}2)${reset} Run Registry Editor (regedit)"
        echo -e "  ${wine}3)${reset} Run Control Panel (control)"
        echo -e "  ${wine}4)${reset} Run File Manager (explorer)"
        echo -e "  ${wine}5)${reset} Run Command Prompt (cmd)"
        echo -e "  ${wine}6)${reset} Reboot Wine Prefix (wineboot -r)"
        echo -e "  ${wine}7)${reset} Shutdown Wine Server (wineserver -k)"
        echo -e "  ${wine}8)${reset} Monitor XWayland Keyboard Events (xev)"
        echo -e "  ${wine}9)${reset} Run Custom Installer/Executable (.exe/.msi)"
        echo -e "  ${wine}10)${reset} Open C: Drive in Host File Manager"
        echo -e "  ${wine}11)${reset} [Back to main menu]"
        echo ""
        read -p "Select an option (1-11): " opt_wine
        local ft_int=$(get_config_val "freetype_interpreter" "40")
        local should_prompt=true
        case "$opt_wine" in
            1)
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; winecfg" || true
                ;;
            2)
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; regedit" || true
                ;;
            3)
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wine control" || true
                ;;
            4)
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wine explorer" || true
                ;;
            5)
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wine cmd" || true
                ;;
            6)
                echo "Rebooting Wine prefix..."
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wineboot -r" || true
                echo "Prefix reboot completed."
                ;;
            7)
                echo "Shutting down Wine server..."
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; wineserver -k" || true
                echo "Wine server shutdown complete."
                ;;
            8)
                if ! distrobox enter "$TORQUIO_CONTAINER_NAME" -- command -v xev >/dev/null 2>&1; then
                    echo "xev (X11 Event Viewer) is not installed in the container."
                    read -p "Would you like to install it now? [Y/n]: " install_xev
                    if [[ ! "$install_xev" =~ ^[Nn]$ ]]; then
                        echo "Installing x11-utils..."
                        distrobox enter "$TORQUIO_CONTAINER_NAME" -- sudo apt update
                        distrobox enter "$TORQUIO_CONTAINER_NAME" -- sudo apt install -y x11-utils
                    else
                        clear
                        continue
                    fi
                fi
                echo "Launching X11 Event Viewer (xev)..."
                echo "Focus the small white window that appears and press keys to monitor events."
                echo "Press Ctrl+C inside this terminal to exit the monitor."
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- xev -event keyboard || true
                ;;
            9)
                run_custom_exe
                ;;
            10)
                if [ -d "$TORQUIO_PREFIX_DIR/drive_c" ]; then
                    echo "Opening C: Drive in host file manager..."
                    xdg-open "$TORQUIO_PREFIX_DIR/drive_c" >/dev/null 2>&1 &
                    should_prompt=false
                else
                    echo "Error: Wine prefix C: drive does not exist yet."
                fi
                ;;
            *)
                return
                ;;
        esac
        if [ "$should_prompt" = "true" ]; then
            echo ""
            read -p "Press [Enter] to continue..." temp_wine
        fi
        clear
    done
}

show_menu() {
    while true; do
        print_header
        echo ""
        
        # Check if environment is active (container exists and core is installed)
        local env_active=false
        if distrobox list 2>/dev/null | grep -q "$TORQUIO_CONTAINER_NAME" && [ -f "$TORQUIO_PREFIX_DIR/.torquio_core_installed" ]; then
            env_active=true
        fi
        
        local wine="\033[38;5;125m"
        local reset="\033[0m"
        
        if [ "$env_active" = "true" ]; then
            echo -e "  ${wine}1)${reset} Reinstall/Update Torquio Environment"
            echo -e "  ${wine}2)${reset} Uninstall/Wipe Torquio"
            echo -e "  ${wine}3)${reset} Status Dashboard"
            echo -e "  ${wine}4)${reset} Configure Graphics & Scaling"
            echo -e "  ${wine}5)${reset} Fix Icons & Refresh Launchers"
            echo -e "  ${wine}6)${reset} Manage Folder Mappings (Map/Unmap)"
            echo -e "  ${wine}7)${reset} Manage Dorico Key Commands"
            echo -e "  ${wine}8)${reset} Wine Tools & Maintenance"
            echo -e "  ${wine}9)${reset} Exit"
            echo ""
            read -p "Select an option (1-9): " choice
            echo ""
            case "$choice" in
                1)  "$SCRIPT_DIR/scripts/install.sh" ;;
                2)  "$SCRIPT_DIR/scripts/cleanup.sh" ;;
                3)  show_status ;;
                4)  configure_graphics; clear; continue ;;
                5)  distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "cd \"$TORQUIO_REPO_DIR\" && ./scripts/2-install/extract_icons.sh" ;;
                6)  manage_folder_mappings; clear; continue ;;
                7)  manage_keycommands; clear; continue ;;
                8)  manage_wine; clear; continue ;;
                9)  exit 0 ;;
                *)  echo "Invalid option. Please choose 1-9." ;;
            esac
        else
            echo -e "  ${wine}1)${reset} Install Torquio Environment"
            echo -e "  ${wine}2)${reset} Clean/Remove Torquio"
            echo -e "  ${wine}3)${reset} Status Dashboard"
            echo -e "  ${wine}4)${reset} Exit"
            echo ""
            read -p "Select an option (1-4): " choice
            echo ""
            case "$choice" in
                1)  "$SCRIPT_DIR/scripts/install.sh" ;;
                2)  "$SCRIPT_DIR/scripts/cleanup.sh" ;;
                3)  show_status ;;
                4)  exit 0 ;;
                *)  echo "Invalid option. Please choose 1-4." ;;
            esac
        fi
        
        echo ""
        read -p "Press [Enter] to return to the main menu..." temp
        clear
    done
}

# --- CLI Flag Parsing Mode ---
if [ $# -gt 0 ]; then
    case "$1" in
        -i|--install|--reinstall)
            shift
            "$SCRIPT_DIR/scripts/install.sh" "$@"
            ;;
        -r|--remove|--uninstall)
            shift
            "$SCRIPT_DIR/scripts/cleanup.sh" "$@"
            ;;
        -f|--fix-icons)
            distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "cd \"$TORQUIO_REPO_DIR\" && ./scripts/2-install/extract_icons.sh"
            ;;
        -g|--graphics)
            configure_graphics
            ;;
        -s|--status)
            show_status
            ;;
        -u|--update)
            "$SCRIPT_DIR/scripts/2-install/update_mediabay.sh"
            ;;
        -d|--map_folder)
            map_folder "$2" "$3"
            ;;
        -x|--export_key_commands)
            export_keycommands
            ;;
        -m|--import_key_commands)
            import_keycommands
            ;;
        -w|--winecfg)
            ft_int=$(get_config_val "freetype_interpreter" "40")
            distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; winecfg" || true
            ;;
        -k|--kill_wine)
            echo "Shutting down Wine server..."
            distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; wineserver -k" || true
            echo "Wine server shutdown complete."
            ;;
        -b|--reboot)
            echo "Rebooting Wine prefix..."
            ft_int=$(get_config_val "freetype_interpreter" "40")
            distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$ft_int\"; wineboot -r" || true
            echo "Prefix reboot completed."
            ;;
        -e|--execute|--run)
            run_custom_exe "$2"
            ;;
        *)
            echo "Error: Unknown argument '$1'"
            echo "Usage: ./torquio [flags]"
            echo "Flags:"
            echo "  -i, --install, --reinstall  Run clean container/prefix setup."
            echo "  -r, --remove, --uninstall   Complete environment purge."
            echo "  -f, --fix-icons             Refresh host desktop icons."
            echo "  -g, --graphics              Interact with display scaling configs."
            echo "  -s, --status                Display status dashboard."
            echo "  -u, --update                Update MediaBay."
            echo "  -d, --map_folder [p] [l]    Map folder positional/interactively."
            echo "  -x, --export_key_commands   Export key commands to zip."
            echo "  -m, --import_key_commands   Import key commands zip/json."
            echo "  -w, --winecfg               Launch winecfg in the container prefix."
            echo "  -k, --kill_wine             Shutdown all active Wine/Steinberg processes."
            echo "  -b, --reboot                Simulate a Windows reboot inside the prefix."
            echo "  -e, --execute, --run [file] Execute a custom .exe or .msi in the prefix."
            exit 1
            ;;
    esac
else
    # Interactive menu mode
    clear
    show_menu
fi
