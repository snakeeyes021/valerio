export_keycommands() {
    echo "=== Exporting Key Commands Backup ==="
    local keycommands_dir=$(find "$TORQUIO_PREFIX_DIR/drive_c/users" -type d -path "*/AppData/Roaming/Steinberg/Dorico*" 2>/dev/null | head -n 1)
    if [ -z "$keycommands_dir" ] || [ ! -d "$keycommands_dir" ]; then
        echo "Error: Dorico AppData directory not found. Please make sure Dorico has been installed and run."
        return
    fi
    
    mapfile -t files < <(find "$keycommands_dir" -type f -name "keycommands_*.json" 2>/dev/null)
    if [ ${#files[@]} -eq 0 ]; then
        echo "No keycommands_*.json files found to export."
        return
    fi
    
    echo "Found files to export:"
    for f in "${files[@]}"; do
        echo "  - $(basename "$f")"
    done
    
    local downloads_dir="${XDG_DOWNLOAD_DIR:-$HOME/Downloads}"
    mkdir -p "$downloads_dir"
    local zip_file="$downloads_dir/torquio_keycommands_backup.zip"
    
    (cd "$keycommands_dir" && zip -q "$zip_file" keycommands_*.json)
    echo "Successfully compressed and exported key commands to: $zip_file"
}

import_keycommands() {
    echo "=== Importing Key Commands Backup ==="
    
    local downloads_dir="${XDG_DOWNLOAD_DIR:-$HOME/Downloads}"
    mapfile -t backups < <(find "$downloads_dir" -maxdepth 1 -type f \( -name "torquio_keycommands_backup.zip" -o -name "keycommands_*.json" \) 2>/dev/null)
    
    local selected_backup=""
    if [ ${#backups[@]} -eq 1 ]; then
        selected_backup="${backups[0]}"
        echo "Auto-detected backup file: $(basename "$selected_backup")"
    elif [ ${#backups[@]} -gt 1 ]; then
        echo "Multiple backup files found in $downloads_dir:"
        for i in "${!backups[@]}"; do
            echo "  $((i+1))) $(basename "${backups[$i]}")"
        done
        echo "  $(( ${#backups[@]} + 1 ))) [Browse...]"
        read -p "Select a file to import (1-$(( ${#backups[@]} + 1 ))): " choice
        if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#backups[@]}" ]; then
            selected_backup="${backups[$((choice-1))]}"
        fi
    fi
    
    if [ -z "$selected_backup" ]; then
        if command -v zenity >/dev/null 2>&1; then
            selected_backup=$(zenity --file-selection --file-filter="Backup (*.zip *.json) | *.zip *.json" --title="Select Key Commands Backup File" 2>/dev/null) || true
        elif command -v kdialog >/dev/null 2>&1; then
            selected_backup=$(kdialog --getopenfilename "$downloads_dir" "*.zip *.json" --title="Select Key Commands Backup File" 2>/dev/null) || true
        else
            read -p "Enter path to key commands backup file (.zip or .json): " selected_backup
        fi
    fi
    
    if [ -z "$selected_backup" ] || [ ! -f "$selected_backup" ]; then
        echo "No backup file selected. Import cancelled."
        return
    fi
    
    echo "Staging backup: $selected_backup"
    
    # Clean up any existing staged files to prevent conflicts
    rm -rf "$TORQUIO_DATA_DIR/staged_keycommands"
    rm -f "$TORQUIO_DATA_DIR"/staged_keycommands.*
    mkdir -p "$TORQUIO_DATA_DIR/staged_keycommands"
    
    if [[ "$selected_backup" =~ \.zip$ ]]; then
        unzip -o "$selected_backup" -d "$TORQUIO_DATA_DIR/staged_keycommands/" >/dev/null 2>&1 || true
    else
        cp "$selected_backup" "$TORQUIO_DATA_DIR/staged_keycommands/"
    fi
    echo "Keyboard shortcuts staged successfully! They will be automatically imported the next time you launch Dorico."
}

