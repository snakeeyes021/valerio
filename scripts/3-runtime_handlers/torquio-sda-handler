#!/bin/bash
set -e

# --- Logging Setup ---
TORQUIO_LOG_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/torquio/logs"
mkdir -p "$TORQUIO_LOG_DIR"
(ls -t "$TORQUIO_LOG_DIR"/*.log 2>/dev/null | tail -n +21 | xargs rm -f 2>/dev/null) &
LOG_FILE="$TORQUIO_LOG_DIR/torquio_sda_$(date +%Y-%m-%d_%H-%M-%S).log"
exec > >(tee -i "$LOG_FILE") 2>&1
echo "=== Torquio SDA Log Started: $(date) ==="
echo "Script: $0"
echo "========================================="

TORQUIO_CONTAINER_NAME="torquio-env"
TORQUIO_PREFIX_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/torquio/prefix"
WINE_CUSTOM_BIN="/opt/wine-custom/bin"
export DBUS_SYSTEM_BUS_ADDRESS="unix:path=/run/host/run/dbus/system_bus_socket"
TORQUIO_REPO_DIR="@TORQUIO_REPO_DIR@"
URL="$1"

get_config_val() {
    local key="$1"
    local default="$2"
    local config_file="$HOME/.config/torquio/config.json"
    if [ ! -f "$config_file" ]; then
        echo "$default"
        return
    fi
    python3 -c "import json; d=json.load(open('$config_file')); v=d.get('$key', '$default'); print(str(v).lower() if isinstance(v, bool) else v)" 2>/dev/null || echo "$default"
}

set_config_val() {
    local key="$1"
    local val="$2"
    local config_file="$HOME/.config/torquio/config.json"
    mkdir -p "$(dirname "$config_file")"
    if [ ! -f "$config_file" ]; then
        echo "{}" > "$config_file"
    fi
    python3 -c "
import json
f = '$config_file'
try: d = json.load(open(f))
except Exception: d = {}
val = '$val'
if val.lower() == 'true': val = True
elif val.lower() == 'false': val = False
elif val.isdigit(): val = int(val)
d['$key'] = val
json.dump(d, open(f, 'w'), indent=4)
" 2>/dev/null || true
}

clean_desktop_lnk() {
    local host_desktop="${XDG_DESKTOP_DIR:-$HOME/Desktop}"
    if [ -f "$HOME/.config/user-dirs.dirs" ]; then
        host_desktop=$( (source "$HOME/.config/user-dirs.dirs" 2>/dev/null && echo "${XDG_DESKTOP_DIR:-$HOME/Desktop}") || echo "$host_desktop" )
    fi
    for dir in "$host_desktop" "$TORQUIO_PREFIX_DIR/drive_c/users/Public/Desktop" "$TORQUIO_PREFIX_DIR"/drive_c/users/*/Desktop; do
        if [ -d "$dir" ]; then
            find "$dir" -maxdepth 1 -type f \( \
                -name "Activation Manager.lnk" -o \
                -name "Steinberg Activation Manager.lnk" -o \
                -name "Dorico*.lnk" -o \
                -name "HALion*.lnk" -o \
                -name "Groove Agent*.lnk" -o \
                -name "Steinberg Library Manager.lnk" \
            \) -delete 2>/dev/null || true
        fi
    done
}

# --- Host Scale & DPI Management ---
MANAGE_GRAPHICS=$(get_config_val "manage_graphics" "false")
MANUAL_DPI=$(get_config_val "manual_dpi" "96")
FREETYPE_INTERP=$(get_config_val "freetype_interpreter" "40")

DPI_TO_SET="$MANUAL_DPI"

if [ -z "$URL" ] && [ "$XDG_SESSION_TYPE" != "x11" ] && [ "$MANAGE_GRAPHICS" = "true" ]; then
    # Since we are using the template placeholder for @TORQUIO_REPO_DIR@, we can look there for the script or use SCRIPT_DIR
    SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
    # Fallback to repo dir if run from a different context
    if [ ! -f "$SCRIPT_DIR/torquio_graphics.py" ]; then
        SCRIPT_DIR="$TORQUIO_REPO_DIR/scripts/3-runtime_handlers"
    fi
if [ "$XDG_SESSION_TYPE" != "x11" ] && [ "$MANAGE_GRAPHICS" = "true" ]; then
    GRAPHICS_JSON=$(python3 "$SCRIPT_DIR/torquio_graphics.py")
    SUPPORTED=$(echo "$GRAPHICS_JSON" | grep -o '"supported": true')
    if [ -n "$SUPPORTED" ]; then
        DE=$(echo "$GRAPHICS_JSON" | grep -o '"de": "[^"]*' | cut -d'"' -f4)
        TARGET_DPI=$(echo "$GRAPHICS_JSON" | grep -o '"target_wine_dpi": [0-9]*' | cut -d' ' -f2)
        TARGET_FACTOR=$(echo "$GRAPHICS_JSON" | grep -o '"target_xwayland_factor": [0-9]*' | cut -d' ' -f2)
        SCALE=$(echo "$GRAPHICS_JSON" | grep -o '"scale": [0-9.]*' | cut -d' ' -f2)
        
        if [ -n "$TARGET_DPI" ] && [ "$TARGET_DPI" -gt 0 ]; then
            DPI_TO_SET="$TARGET_DPI"
        fi
        
        WARN_DISMISSED=$(get_config_val "warn_xwayland_change" "false")
        
        HOST_CHANGE_NEEDED=false
        DESIRED_POLICY=""
        
        if [ "$DE" = "GNOME" ]; then
            CURRENT_POLICY=$(gsettings get org.gnome.mutter.wayland xwayland-scaling-factor 2>/dev/null | awk '{print $NF}')
            if [ -z "$CURRENT_POLICY" ]; then
                CURRENT_POLICY=$(gsettings get org.gnome.mutter xwayland-scaling-factor 2>/dev/null | awk '{print $NF}')
            fi
            CURRENT_POLICY=$(echo "$CURRENT_POLICY" | tr -d ' ' | cut -d'.' -f1 | tr -cd '0-9')
            
            DESIRED_POLICY="$TARGET_FACTOR"
            if [ "$TARGET_FACTOR" -gt 1 ] && { [ "$CURRENT_POLICY" = "0" ] || [ -z "$CURRENT_POLICY" ]; }; then
                DESIRED_POLICY="$CURRENT_POLICY"
            fi
            if [ "$DESIRED_POLICY" = "1" ] && { [ "$CURRENT_POLICY" = "0" ] || [ -z "$CURRENT_POLICY" ]; }; then
                if [ "$SCALE" = "1" ] || [ "$SCALE" = "1.0" ] || [ "$SCALE" = "1.00" ] || [ -z "$SCALE" ]; then
                    DESIRED_POLICY="$CURRENT_POLICY"
                fi
            fi
            
            if [ -n "$DESIRED_POLICY" ] && [ "$CURRENT_POLICY" != "$DESIRED_POLICY" ]; then
                HOST_CHANGE_NEEDED=true
            fi
        elif [ "$DE" = "KDE" ]; then
            kread_bin="kreadconfig6"
            command -v kreadconfig6 >/dev/null 2>&1 || kread_bin="kreadconfig5"
            kwrite_bin="kwriteconfig6"
            command -v kwriteconfig6 >/dev/null 2>&1 || kwrite_bin="kwriteconfig5"
            CURRENT_POLICY=$($kread_bin --file kdeglobals --group KScreen --key XwaylandClientsScale 2>/dev/null)
            if [ -z "$CURRENT_POLICY" ]; then
                CURRENT_POLICY=$($kread_bin --file kdeglobals --group KScreen --key XwaylandClientScale 2>/dev/null)
            fi
            if [ -z "$CURRENT_POLICY" ]; then
                CURRENT_POLICY="true"
            fi
            if [ "$CURRENT_POLICY" != "true" ]; then
                HOST_CHANGE_NEEDED=true
            fi
        elif [ "$DE" = "COSMIC" ]; then
            CURRENT_POLICY=$(cat ~/.config/cosmic/com.system76.CosmicComp/v1/descale_xwayland 2>/dev/null)
            DESIRED_POLICY="fractional"
            if [ "$SCALE" = "1" ] || [ "$SCALE" = "1.0" ] || [ "$SCALE" = "1.00" ]; then
                DESIRED_POLICY="$CURRENT_POLICY"
            fi
            if [ "$CURRENT_POLICY" != "$DESIRED_POLICY" ]; then
                HOST_CHANGE_NEEDED=true
            fi
        fi
        
        # Check WINE DPI key
        CURRENT_REG_DPI=$(distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; wine reg query \"HKCU\\Control Panel\\Desktop\" /v LogPixels 2>/dev/null" | grep -o '0x[0-9a-fA-F]*' | xargs printf "%d" 2>/dev/null || echo "96")
        
        WINE_CHANGE_NEEDED=false
        if [ "$CURRENT_REG_DPI" != "$DPI_TO_SET" ]; then
            WINE_CHANGE_NEEDED=true
        fi
        
        if [ "$HOST_CHANGE_NEEDED" = "true" ] || [ "$WINE_CHANGE_NEEDED" = "true" ]; then
            active_apps_running=false
            if distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "ps auxww" | grep -iE "Dorico.*\.exe|Download.*Assistant.*\.exe|Activation.*Manager.*\.exe|aria2c" | grep -v grep >/dev/null 2>&1; then
                active_apps_running=true
            fi
            
            should_apply=true
            
            if [ "$active_apps_running" = "true" ]; then
                # Check if we can restart (not in redirect flow)
                if [ -z "$URL" ]; then
                    warn_msg="Torquio detected a display scaling change. To apply this change, the active WINE session needs to be restarted.\n\nWould you like Torquio to close active applications and apply the new scaling now?"
                    if command -v zenity >/dev/null 2>&1; then
                        zenity --question --title="Torquio Graphics Change" --text="$warn_msg" --width=400 2>/dev/null || should_apply=false
                    elif command -v kdialog >/dev/null 2>&1; then
                        kdialog --yesno "$warn_msg" --title "Torquio Graphics Change" 2>/dev/null || should_apply=false
                    else
                        should_apply=true
                    fi
                else
                    should_apply=false
                fi
            fi
            
            if [ "$should_apply" = "true" ]; then
                # Apply host scaling change if needed
                if [ "$HOST_CHANGE_NEEDED" = "true" ]; then
                    if [ "$WARN_DISMISSED" != "true" ]; then
                        warn_msg="You've configured Torquio to automatically handle graphics/scaling changes. Torquio is about to adjust your global XWayland scaling policy for optimal Dorico performance.\n\nReminder: This is a persistent system setting change and may affect the scaling of other running XWayland applications. Your current settings will be backed up first so they can be easily restored later.\n\nProceed with applying this change?"
                        if command -v zenity >/dev/null 2>&1; then
                            zenity --question --title="Torquio Graphics Management" --text="$warn_msg" || exit 1
                        elif command -v kdialog >/dev/null 2>&1; then
                            kdialog --yesno "$warn_msg" --title "Torquio Graphics Management" || exit 1
                        fi
                        set_config_val "warn_xwayland_change" "true"
                    fi
                    
                    if [ "$DE" = "GNOME" ]; then
                        backup_val=$(get_config_val "original_scale_factor" "")
                        if [ -z "$backup_val" ]; then
                            set_config_val "original_scale_factor" "${CURRENT_POLICY:-0}"
                        fi
                        if gsettings list-schemas | grep -q org.gnome.mutter.wayland; then
                            gsettings set org.gnome.mutter.wayland xwayland-scaling-factor "$DESIRED_POLICY" 2>/dev/null || true
                        else
                            gsettings set org.gnome.mutter xwayland-scaling-factor "$DESIRED_POLICY" 2>/dev/null || true
                        fi
                    elif [ "$DE" = "KDE" ]; then
                        backup_val=$(get_config_val "original_kde_policy" "")
                        if [ -z "$backup_val" ]; then
                            set_config_val "original_kde_policy" "${CURRENT_POLICY:-false}"
                        fi
                        $kwrite_bin --file kdeglobals --group KScreen --key XwaylandClientsScale true 2>/dev/null || true
                        $kwrite_bin --file kdeglobals --group KScreen --key XwaylandClientScale true 2>/dev/null || true
                        dbus-send --session --dest=org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
                    elif [ "$DE" = "COSMIC" ]; then
                        backup_val=$(get_config_val "original_cosmic_policy" "")
                        if [ -z "$backup_val" ]; then
                            set_config_val "original_cosmic_policy" "${CURRENT_POLICY:-none}"
                        fi
                        mkdir -p ~/.config/cosmic/com.system76.CosmicComp/v1
                        echo "$DESIRED_POLICY" > ~/.config/cosmic/com.system76.CosmicComp/v1/descale_xwayland 2>/dev/null || true
                    fi
                fi
                
                # Apply WINE registry DPI change if needed
                if [ "$WINE_CHANGE_NEEDED" = "true" ]; then
                    distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; export FREETYPE_PROPERTIES=\"truetype:interpreter-version=$FREETYPE_INTERP\"; wine reg add \"HKCU\\Control Panel\\Desktop\" /v LogPixels /t REG_DWORD /d $DPI_TO_SET /f" >/dev/null 2>&1 || true
                fi
                
                # Restart wineserver
                distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "export WINEPREFIX=\"$TORQUIO_PREFIX_DIR\"; export PATH=\"$WINE_CUSTOM_BIN:\$PATH\"; wineserver -k && wineserver -w" >/dev/null 2>&1 || true
            fi
        fi
    fi
fi
fi

# --- Keyboard Auto-Repeat Lag Remedy (xset) ---
distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c 'xset r rate 500 30 && for keycode in {10..21} 23 {24..35} 36 {38..49} 51 {52..61} 65; do xset -r $keycode; done' >/dev/null 2>&1 || true

# Ensure log directory exists
mkdir -p "$HOME/.local/share/torquio"

if [ -z "$URL" ]; then
    # Start background watcher for Dorico installation and desktop shortcut cleanup
    (
        echo "Starting background watcher for Dorico installation and shortcut cleanup..."
        
        # Clean up old status files to avoid stale matches
        find "$TORQUIO_PREFIX_DIR/drive_c/users" -path "*/AppData/Local/Temp/*" -name "*.json" -delete 2>/dev/null || true
        
        # Wait up to 30 seconds for the SDA processes to start active first
        echo "Waiting for SDA processes to start..."
        SDA_STARTED=false
        for i in {1..15}; do
            if distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "ps auxww" | grep -iE "Steinberg Download Assistant\.exe|STEI~B2R\.EXE|aria2c\.exe" > /dev/null; then
                echo "SDA processes detected active."
                SDA_STARTED=true
                break
            fi
            sleep 2
        done

        if [ "$SDA_STARTED" = "true" ]; then
            while true; do
                # Clean up any virtual/unfunctional Windows desktop shortcuts created by installers
                clean_desktop_lnk
                
                # 1. Check if Dorico success status file has been written
                DORICO_STATUS_FILE=$(find "$TORQUIO_PREFIX_DIR/drive_c/users" -path "*/AppData/Local/Temp/*" -name "*Dorico*Application*Installer.json" 2>/dev/null | head -n 1)
                
                if [ -n "$DORICO_STATUS_FILE" ] && [ -f "$DORICO_STATUS_FILE" ]; then
                    artifactId=$(grep -o '"artifactId":\s*"[^"]*"' "$DORICO_STATUS_FILE" | head -n 1 | cut -d'"' -f4)
                    success=$(grep -o '"success":\s*\(true\|false\)' "$DORICO_STATUS_FILE" | head -n 1 | cut -d':' -f2 | tr -d '[:space:]')
                    
                    if [[ "$artifactId" =~ Dorico.*Application_Installer ]] && [ "$success" = "true" ]; then
                        echo "Dorico installation success detected! Extracting icons..."
                        distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "cd \"$TORQUIO_REPO_DIR\" && ./scripts/2-install/extract_icons.sh"
                        mv "$DORICO_STATUS_FILE" "${DORICO_STATUS_FILE}.processed" 2>/dev/null || rm -f "$DORICO_STATUS_FILE"
                    fi
                fi
                
                # 2. Check if the SDA processes have terminated (fallback in case of exit/cancel without installing)
                if ! distrobox enter "$TORQUIO_CONTAINER_NAME" -- bash -c "ps auxww" | grep -iE "Steinberg Download Assistant\.exe|STEI~B2R\.EXE|aria2c\.exe" > /dev/null; then
                    echo "SDA processes terminated. Exiting watcher."
                    break
                fi
                
                sleep 4
            done
        else
            echo "SDA processes never started. Exiting watcher."
        fi
    ) > "$HOME/.local/share/torquio/sda_watcher.log" 2>&1 &
fi

# --- Dynamic Runner Script Generation (Space & Quoting Safeguard) ---
RUNNER_SCRIPT="$HOME/.local/share/torquio/run-sda.sh"
mkdir -p "$(dirname "$RUNNER_SCRIPT")"
cat << EOF > "$RUNNER_SCRIPT"
#!/bin/bash
export DBUS_SYSTEM_BUS_ADDRESS="unix:path=/run/host/run/dbus/system_bus_socket"
export WINEPREFIX="$TORQUIO_PREFIX_DIR"
export WINEDLLOVERRIDES="winemenubuilder.exe=d"
export PATH="$WINE_CUSTOM_BIN:\$PATH"
export FREETYPE_PROPERTIES="truetype:interpreter-version=$FREETYPE_INTERP"

URL_FILE="\$HOME/.local/share/torquio/sda_url.txt"
URL=""
if [ -f "\$URL_FILE" ]; then
    URL=\$(cat "\$URL_FILE")
    rm -f "\$URL_FILE"
fi

if [ -n "\$URL" ]; then
    wine 'C:\Program Files (x86)\Steinberg\Download Assistant\Steinberg Download Assistant.exe' "\$URL"
else
    wine 'C:\Program Files (x86)\Steinberg\Download Assistant\Steinberg Download Assistant.exe'
fi
EOF
chmod +x "$RUNNER_SCRIPT"

if [ -n "$URL" ]; then
    echo "$URL" > "$HOME/.local/share/torquio/sda_url.txt"
else
    rm -f "$HOME/.local/share/torquio/sda_url.txt"
fi

# Sweep before launching to catch any leftovers
clean_desktop_lnk

distrobox enter "$TORQUIO_CONTAINER_NAME" -- "$RUNNER_SCRIPT"

# Sweep after exiting to catch any shortcuts written right at the end
clean_desktop_lnk
